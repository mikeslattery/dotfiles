# This is a universal .editorconfig for all projects
# that don't have one.
# see also ~/.config/git/templates/README.md

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# 2 space
[{*.js,*.ts,*.rb}]
indent_size = 2
max_line_length = 100

# 4 space
[{*.java,*.kt,*.go,*.py}]
indent_size = 4
max_line_length = 100

# Tab
[Makefile]
indent_style = tab

[*.md]
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Windows
[{*.bat,*.ps1,*.cs}]
indent_size = 4
end_of_line = crlf

# Text files we don't care about
[{*.svg}]
charset = utf-8
end_of_line = unset
insert_final_newline = unset
indent_style = unset
indent_size = unset
trim_trailing_whitespace = unset

[{.run/*.xml,fixture/**}]
end_of_line = unset
insert_final_newline = unset
indent_style = unset
indent_size = unset
trim_trailing_whitespace = unset
