#!/bin/bash

# git convenience utility
# 1) pick file list operations, 2) pick listed files, 3) list file operations, 4) do operation
# Reqires: git, fzf, bat, eza

set -euo pipefail

read-ops() {
	echo -n "git ls-files --others --exclude-standard
git diff --name-only
git diff --name-only --cached
git ls-files
fd --hidden --no-ignore -E .git -E node_modules
"
}


write-ops() {
	echo -n "git add
git --paginate diff
git --paginate diff --cached
git --no-pager diff
git checkout
git reset
git rm
git --paginate log
git stash push --
bat
rm
printf %s\n
${EDITOR:-nano}
"
}

git-status() {
    git --no-pager -c color.ui=always status -s -uno | sort
}
OLDSTATUS="$(git-status)"

LIST_PREVIEW='xargs -d"\n" -r eza --color=always -dl --git --no-user --no-permissions --no-time --no-filesize'
# Use diff, else content
FILE_PREVIEW='eza --color=always -dl --git --no-user {}; git diff --quiet {} && bat --color=always --style=numbers,grid {} || (git diff {} | bat -l diff --color=always --style=grid )'

readop="$(read-ops | fzf --preview "GIT_PAGER='' bash -c {} | $LIST_PREVIEW")"
bash -c "$readop" | fzf -m --bind 'alt-a:select-all' --preview "$FILE_PREVIEW" >/tmp/files.txt

writeop="$(write-ops "$readop" | fzf --preview "cat /tmp/files.txt | $LIST_PREVIEW")"
echo -n '+ ' >&2
cat /tmp/files.txt | xargs -d"\n" -tr $writeop
rm /tmp/files.txt

# Show status, if changed
NEWSTATUS="$(git-status)"
if [[ "$OLDSTATUS" != "$NEWSTATUS" ]]; then
    echo "$NEWSTATUS" >&2
fi

